<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Escrituras do Coração | Caderno Messiânico</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(145deg, #f9f3e6 0%, #f0e7d6 100%);
            font-family: 'Segoe UI', 'Roboto', 'Georgia', 'Times New Roman', serif;
            padding: 1.5rem;
            color: #2c2418;
        }

        /* papel envelhecido + toque judaico */
        .container {
            max-width: 1200px;
            margin: 0 auto;
            background: #fffef7;
            border-radius: 32px;
            box-shadow: 0 20px 35px -12px rgba(0, 0, 0, 0.2), inset 0 1px 0 rgba(255,255,255,0.8);
            overflow: hidden;
            border: 1px solid #dbcbaa;
        }

        /* cabeçalho com símbolos messiânicos */
        .header {
            background: #1e2f3b;
            padding: 1.2rem 2rem;
            border-bottom: 5px solid #c9a03d;
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: baseline;
            gap: 1rem;
        }

        .title-section h1 {
            font-size: 1.9rem;
            font-weight: 500;
            letter-spacing: 1px;
            color: #f7e5c2;
            font-family: 'Times New Roman', serif;
            text-shadow: 2px 2px 0 #0f1e26;
        }

        .title-section h1 span {
            font-size: 1.6rem;
            display: inline-block;
        }

        .title-section p {
            color: #d4bc8a;
            font-style: italic;
            font-size: 0.9rem;
            margin-top: 6px;
        }

        .messianic-icons {
            display: flex;
            gap: 18px;
            font-size: 1.8rem;
            background: #2a3f4b;
            padding: 8px 18px;
            border-radius: 60px;
        }

        .messianic-icons span {
            cursor: default;
            filter: drop-shadow(0 2px 2px rgba(0,0,0,0.3));
        }

        /* grid principal: editor + lista */
        .main-dashboard {
            display: flex;
            flex-wrap: wrap;
            gap: 2rem;
            padding: 2rem 2rem 2rem 2rem;
        }

        /* área de criação */
        .creation-panel {
            flex: 1.4;
            min-width: 260px;
            background: #fefaf2;
            border-radius: 28px;
            padding: 1.4rem;
            box-shadow: 0 8px 18px rgba(0, 0, 0, 0.05), inset 0 0 0 1px #fff9ef;
            border: 1px solid #e2d5bd;
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

        label {
            display: flex;
            align-items: center;
            gap: 8px;
            font-weight: 600;
            color: #6b4c2c;
            margin-bottom: 8px;
            font-size: 1rem;
            letter-spacing: 0.3px;
        }

        label i {
            font-size: 1.2rem;
        }

        select, input, textarea {
            width: 100%;
            padding: 12px 16px;
            background: #ffffff;
            border: 1.5px solid #e2cfaa;
            border-radius: 24px;
            font-family: 'Georgia', 'Times New Roman', serif;
            font-size: 1rem;
            transition: all 0.2s;
            outline: none;
            color: #2f241b;
        }

        select:focus, input:focus, textarea:focus {
            border-color: #b8863b;
            box-shadow: 0 0 0 3px rgba(184,134,59,0.2);
        }

        textarea {
            resize: vertical;
            min-height: 180px;
            line-height: 1.5;
        }

        .btn-group {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            margin-top: 10px;
        }

        button {
            background: #f0e2ce;
            border: none;
            padding: 10px 22px;
            border-radius: 40px;
            font-weight: bold;
            font-size: 0.9rem;
            cursor: pointer;
            transition: 0.2s;
            font-family: inherit;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: #3b2a1f;
            border: 1px solid #dbbb86;
        }

        button.primary {
            background: #b8863b;
            color: white;
            border: none;
            box-shadow: 0 3px 6px rgba(0,0,0,0.1);
        }

        button.primary:hover {
            background: #9b6a2c;
            transform: translateY(-2px);
        }

        button.secondary {
            background: #e8d9c2;
        }

        button.secondary:hover {
            background: #dbcaad;
            transform: translateY(-1px);
        }

        button.danger {
            background: #eeddcc;
            color: #a1421a;
            border-color: #e2bc9b;
        }

        button.danger:hover {
            background: #e6c8ae;
            color: #8b2e0a;
        }

        /* lista de escritos */
        .list-panel {
            flex: 2;
            min-width: 320px;
            background: #fdf9f0;
            border-radius: 28px;
            padding: 1.2rem;
            box-shadow: 0 8px 18px rgba(0, 0, 0, 0.05);
            border: 1px solid #e9ddc3;
        }

        .list-header {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            flex-wrap: wrap;
            border-bottom: 2px dashed #dccb9c;
            padding-bottom: 12px;
            margin-bottom: 18px;
        }

        .list-header h2 {
            font-size: 1.5rem;
            font-weight: 500;
            color: #5c401f;
            display: flex;
            gap: 10px;
        }

        .filter-buttons {
            display: flex;
            gap: 6px;
        }

        .filter-btn {
            background: none;
            border: none;
            font-size: 0.75rem;
            padding: 5px 12px;
            border-radius: 30px;
            background: #ede3d1;
            color: #4e3a28;
        }

        .filter-btn.active {
            background: #b8863b;
            color: white;
        }

        .writings-list {
            max-height: 550px;
            overflow-y: auto;
            padding-right: 6px;
        }

        .writing-card {
            background: white;
            border-radius: 24px;
            padding: 1rem 1.2rem;
            margin-bottom: 1rem;
            border-left: 8px solid #c9a03d;
            box-shadow: 0 3px 8px rgba(0,0,0,0.03);
            transition: all 0.2s;
            cursor: pointer;
        }

        .writing-card:hover {
            transform: translateX(4px);
            background: #fffcf4;
            border-left-color: #dbb263;
        }

        .card-type {
            display: inline-block;
            font-size: 0.7rem;
            background: #f1e8da;
            padding: 4px 12px;
            border-radius: 30px;
            margin-bottom: 8px;
            font-weight: bold;
            color: #6b4e2a;
        }

        .card-title {
            font-size: 1.25rem;
            font-weight: 600;
            margin-bottom: 8px;
            color: #2c3e2f;
        }

        .card-preview {
            font-size: 0.85rem;
            color: #5b4a36;
            line-height: 1.4;
            overflow: hidden;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
        }

        .card-actions {
            margin-top: 12px;
            display: flex;
            gap: 12px;
            justify-content: flex-end;
        }

        .card-actions button {
            background: transparent;
            padding: 4px 10px;
            font-size: 0.75rem;
            border: 1px solid #ddcca8;
        }

        .empty-message {
            text-align: center;
            padding: 2rem;
            color: #b89870;
            font-style: italic;
        }

        /* rodapé com oração / shema */
        .footer {
            background: #1e2f3b;
            color: #decb9e;
            text-align: center;
            padding: 1rem;
            font-size: 0.8rem;
            border-top: 1px solid #3f5b66;
            font-family: monospace;
        }

        .footer small {
            letter-spacing: 1px;
        }

        @media (max-width: 780px) {
            body { padding: 0.8rem; }
            .header { flex-direction: column; align-items: center; text-align: center; }
            .messianic-icons { justify-content: center; }
        }
    </style>
</head>
<body>
<div class="container">
    <div class="header">
        <div class="title-section">
            <h1>📜 קודש escritos <span>✡︎ Yeshua</span></h1>
            <p>poesias · pensamentos · orações · textos messiânicos</p>
        </div>
        <div class="messianic-icons">
            <span>🕎</span>
            <span>✡️</span>
            <span>🕊️</span>
            <span>📖</span>
            <span>🌿</span>
        </div>
    </div>

    <div class="main-dashboard">
        <!-- Painel de escrita -->
        <div class="creation-panel">
            <div class="form-group">
                <label><span>✍️</span> Tipo de escrita</label>
                <select id="tipoEscrita">
                    <option value="poesia">🌸 Poesia</option>
                    <option value="pensamento">💭 Pensamento</option>
                    <option value="oracao">🕯️ Oração</option>
                    <option value="escrito">📜 Escrito Messiânico</option>
                </select>
            </div>
            <div class="form-group">
                <label><span>🏷️</span> Título (opcional)</label>
                <input type="text" id="tituloInput" placeholder="Ex: Salmo da Manhã, Shalom interior..." maxlength="80">
            </div>
            <div class="form-group">
                <label><span>🖋️</span> Conteúdo</label>
                <textarea id="conteudoInput" placeholder="Escreva aqui sua poesia, pensamento, oração ou reflexão messiânica... &#10;✡️ 'Alegrai-vos sempre no Senhor; outra vez digo, alegrai-vos.'"></textarea>
            </div>
            <div class="btn-group">
                <button id="salvarBtn" class="primary">💾 Salvar Escrito</button>
                <button id="limparBtn" class="secondary">🗑️ Limpar Campos</button>
            </div>
            <div style="margin-top: 20px; font-size: 0.75rem; color: #aa8b60; text-align: center; border-top: 1px dashed #eedbba; padding-top: 12px;">
                <span>🕊️ “Escreve a visão e torna-a plana sobre tábuas” (Habacuque 2:2)</span>
            </div>
        </div>

        <!-- Lista de escritos -->
        <div class="list-panel">
            <div class="list-header">
                <h2>📖 Meu Caderno <span>|</span> <span id="contadorRegistros">0</span> textos</h2>
                <div class="filter-buttons">
                    <button data-filter="todos" class="filter-btn active">Todos</button>
                    <button data-filter="poesia" class="filter-btn">🌸 Poesia</button>
                    <button data-filter="pensamento" class="filter-btn">💭 Pensamento</button>
                    <button data-filter="oracao" class="filter-btn">🕯️ Oração</button>
                    <button data-filter="escrito" class="filter-btn">📜 Escrito</button>
                </div>
            </div>
            <div id="writingsContainer" class="writings-list">
                <!-- cards dinâmicos -->
                <div class="empty-message">✨ Nenhum escrito ainda. Comece a escrever sua inspiração messiânica!</div>
            </div>
        </div>
    </div>
    <div class="footer">
        <small>שַׁבָּת שָׁלוֹם • Shema Yisrael, Adonai Eloheinu, Adonai Echad • Bendito seja Yeshua, a luz do mundo ✡️🕊️</small>
    </div>
</div>

<script>
    // ---------- MODELO DE DADOS ----------
    let writings = [];      // array de objetos { id, tipo, titulo, conteudo, data }
    let currentFilter = "todos";
    let nextId = 1;

    // Elementos DOM
    const tipoSelect = document.getElementById('tipoEscrita');
    const tituloInput = document.getElementById('tituloInput');
    const conteudoInput = document.getElementById('conteudoInput');
    const salvarBtn = document.getElementById('salvarBtn');
    const limparBtn = document.getElementById('limparBtn');
    const writingsContainer = document.getElementById('writingsContainer');
    const contadorSpan = document.getElementById('contadorRegistros');
    const filterBtns = document.querySelectorAll('.filter-btn');

    // Carregar dados do localStorage (persistência local)
    function loadFromStorage() {
        const stored = localStorage.getItem('messianicWritings');
        if(stored) {
            try {
                writings = JSON.parse(stored);
                if(writings.length > 0) {
                    nextId = Math.max(...writings.map(w => w.id), 0) + 1;
                } else {
                    nextId = 1;
                }
            } catch(e) { writings = []; }
        } else {
            // dados exemplares messiânicos para inspirar
            writings = [
                {
                    id: nextId++,
                    tipo: "poesia",
                    titulo: "Luz do Eterno",
                    conteudo: "Teu amor é mais doce que o mel, Tua palavra é lâmpada para os meus pés. Em meio às águas, Yeshua caminha sobre meu coração.",
                    data: new Date().toISOString()
                },
                {
                    id: nextId++,
                    tipo: "oracao",
                    titulo: "Oração da Manhã Messiânica",
                    conteudo: "Aba Pai, agradeço-Te por mais um dia. Que o Ruach HaKodesh me guie e a Torá esteja gravada em meu coração. Bendito és Tu, Adonai!",
                    data: new Date().toISOString()
                },
                {
                    id: nextId++,
                    tipo: "pensamento",
                    titulo: "Shalom interior",
                    conteudo: "A verdadeira paz não é ausência de guerra, mas a presença do Messias dentro de nós. Shalom shalom.",
                    data: new Date().toISOString()
                }
            ];
            nextId = 4;
            saveToStorage();
        }
        renderWritings();
    }

    function saveToStorage() {
        localStorage.setItem('messianicWritings', JSON.stringify(writings));
    }

    // Função auxiliar: pegar emoji e nome bonito do tipo
    function getTypeInfo(tipo) {
        switch(tipo) {
            case 'poesia': return { emoji: '🌸', label: 'Poesia' };
            case 'pensamento': return { emoji: '💭', label: 'Pensamento' };
            case 'oracao': return { emoji: '🕯️', label: 'Oração' };
            case 'escrito': return { emoji: '📜', label: 'Escrito Messiânico' };
            default: return { emoji: '📝', label: 'Escrito' };
        }
    }

    // Renderizar lista com filtro atual
    function renderWritings() {
        let filtered = writings.filter(w => currentFilter === 'todos' ? true : w.tipo === currentFilter);
        // ordenar por data decrescente (mais novo primeiro)
        filtered.sort((a,b) => new Date(b.data) - new Date(a.data));
        
        if(filtered.length === 0) {
            writingsContainer.innerHTML = `<div class="empty-message">📭 Nenhum ${currentFilter !== 'todos' ? getTypeInfo(currentFilter).label.toLowerCase() : 'escrito'} encontrado. Inspira-te e escreva algo novo! ✡️</div>`;
            contadorSpan.innerText = writings.length;
            return;
        }

        let html = '';
        for(let w of filtered) {
            const typeInfo = getTypeInfo(w.tipo);
            const tituloExib = w.titulo && w.titulo.trim() !== '' ? w.titulo : `Sem título (${typeInfo.label})`;
            const preview = w.conteudo.length > 90 ? w.conteudo.substring(0, 87) + '...' : w.conteudo;
            const dataFormatada = new Date(w.data).toLocaleDateString('pt-BR', { day:'2-digit', month:'short', hour:'2-digit', minute:'2-digit' });
            html += `
                <div class="writing-card" data-id="${w.id}">
                    <div class="card-type">${typeInfo.emoji} ${typeInfo.label}</div>
                    <div class="card-title">${escapeHtml(tituloExib)}</div>
                    <div class="card-preview">${escapeHtml(preview)}</div>
                    <div style="font-size:0.7rem; color:#b48b54; margin-top: 6px;">🕊️ ${dataFormatada}</div>
                    <div class="card-actions">
                        <button class="edit-btn" data-id="${w.id}">✏️ Editar</button>
                        <button class="delete-btn" data-id="${w.id}">🗑️ Excluir</button>
                    </div>
                </div>
            `;
        }
        writingsContainer.innerHTML = html;
        contadorSpan.innerText = writings.length;

        // adicionar eventos de edição/exclusão dinâmicos
        document.querySelectorAll('.edit-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.stopPropagation();
                const id = parseInt(btn.dataset.id);
                editWritingById(id);
            });
        });
        document.querySelectorAll('.delete-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.stopPropagation();
                const id = parseInt(btn.dataset.id);
                deleteWritingById(id);
            });
        });
        // ao clicar no card (opcional carregar no editor para visualização)
        document.querySelectorAll('.writing-card').forEach(card => {
            card.addEventListener('click', (e) => {
                // se clicou em botão, não executa
                if(e.target.classList.contains('edit-btn') || e.target.classList.contains('delete-btn')) return;
                const id = parseInt(card.dataset.id);
                loadWritingToEditor(id);
            });
        });
    }

    // helper escape
    function escapeHtml(str) {
        if(!str) return '';
        return str.replace(/[&<>]/g, function(m) {
            if(m === '&') return '&amp;';
            if(m === '<') return '&lt;';
            if(m === '>') return '&gt;';
            return m;
        }).replace(/[\uD800-\uDBFF][\uDC00-\uDFFF]/g, function(c) {
            return c;
        });
    }

    // salvar (novo ou edição)
    let editingId = null;  // quando estamos editando um item existente

    function saveWriting() {
        const tipo = tipoSelect.value;
        let titulo = tituloInput.value.trim();
        const conteudo = conteudoInput.value.trim();

        if(conteudo === "") {
            alert("Por favor, escreva algo para salvar. Uma poesia, pensamento ou oração abençoada.");
            return;
        }
        if(titulo === "") titulo = "";   // título vazio é permitido

        if(editingId !== null) {
            // modo edição: atualizar o item existente
            const index = writings.findIndex(w => w.id === editingId);
            if(index !== -1) {
                writings[index] = {
                    ...writings[index],
                    tipo: tipo,
                    titulo: titulo,
                    conteudo: conteudo,
                    data: new Date().toISOString()   // atualiza data da edição
                };
                saveToStorage();
                renderWritings();
                clearFormAndEditing();
                alert("✡️ Escrito atualizado com êxito! (Shalom)");
            } else {
                editingId = null;
                saveWriting(); // fallback
            }
        } else {
            // novo registro
            const newWriting = {
                id: nextId++,
                tipo: tipo,
                titulo: titulo,
                conteudo: conteudo,
                data: new Date().toISOString()
            };
            writings.unshift(newWriting);  // mais novo no topo da lista lógica
            saveToStorage();
            renderWritings();
            clearFormAndEditing();
            alert("📖 Salvo no seu caderno messiânico! Bendito seja o Eterno.");
        }
    }

    function editWritingById(id) {
        const writing = writings.find(w => w.id === id);
        if(writing) {
            // carregar no formulário
            tipoSelect.value = writing.tipo;
            tituloInput.value = writing.titulo || "";
            conteudoInput.value = writing.conteudo;
            editingId = writing.id;
            // mudar visual do botão salvar
            salvarBtn.textContent = "✡️ Atualizar Escrito";
            salvarBtn.classList.add("primary");
            // rolar suavemente até o formulário
            document.querySelector('.creation-panel').scrollIntoView({ behavior: 'smooth', block: 'center' });
        } else {
            alert("Escrito não encontrado.");
        }
    }

    function loadWritingToEditor(id) {
        // mesma função de editar, mas sem alterar texto do botão? chamamos edit diretamente
        editWritingById(id);
    }

    function deleteWritingById(id) {
        if(confirm("Tem certeza que deseja excluir este escrito do coração? Essa ação é permanente.")) {
            writings = writings.filter(w => w.id !== id);
            saveToStorage();
            if(editingId === id) clearFormAndEditing();
            renderWritings();
            alert("🗝️ Escrito removido. Que novos textos floresçam.");
        }
    }

    function clearFormAndEditing() {
        tipoSelect.value = "poesia";
        tituloInput.value = "";
        conteudoInput.value = "";
        editingId = null;
        salvarBtn.textContent = "💾 Salvar Escrito";
    }

    // filtros
    function setFilter(filterValue) {
        currentFilter = filterValue;
        filterBtns.forEach(btn => {
            if(btn.dataset.filter === filterValue) {
                btn.classList.add('active');
            } else {
                btn.classList.remove('active');
            }
        });
        renderWritings();
    }

    // event listeners
    salvarBtn.addEventListener('click', saveWriting);
    limparBtn.addEventListener('click', () => {
        clearFormAndEditing();
        alert("Campos limpos. Escreva uma nova inspiração!");
    });
    filterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            setFilter(btn.dataset.filter);
        });
    });

    // carregar dados iniciais
    loadFromStorage();

    // Prevenir perda acidental ao recarregar? Aviso simples
    window.addEventListener('beforeunload', (e) => {
        if(conteudoInput.value.trim() !== "" && editingId === null && writings.length > 0) {
            // opcional: aviso, mas apenas para evitar perda não salva se houver conteúdo e não editando
            if(conteudoInput.value.trim().length > 5 && !confirmAction) {
                // Não utilizamos confirmação automática invasiva; apenas padrão leve
                // não force dialog, deixamos a critério
            }
        }
    });
    let confirmAction = false;
    // não aplicamos prevenção pesada para não incomodar
</script>
</body>
</html>
